{
  "info": {
    "_postman_id": "9b9b9d29-317a-4f32-a4ea-4d9ecf4f4d61",
    "name": "Banamur Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection Postman de base pour tester l'API Banamur Auth. Certaines routes necessitent un token d'un utilisateur ADMIN ou SUPER_ADMIN."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost/banamur_auth/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userId",
      "value": "1"
    },
    {
      "key": "roleId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Verifie que l'API repond."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"motdepasse123\",\n  \"first_name\": \"Alice\",\n  \"last_name\": \"Banamur\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Cree un utilisateur standard avec le role USER."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.user && json.data.user.id) {",
                  "    pm.collectionVariables.set('userId', String(json.data.user.id));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"alice@example.com\",\n  \"password\": \"motdepasse123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Connecte l'utilisateur et stocke automatiquement le token dans la variable de collection token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "}",
                  "if (json && json.data && json.data.user && json.data.user.id) {",
                  "    pm.collectionVariables.set('userId', String(json.data.user.id));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/auth/me",
            "description": "Recupere l'utilisateur correspondant au token courant."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/auth/logout",
            "description": "Deconnecte l'utilisateur courant."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/users",
            "description": "Necessite la permission user.read."
          },
          "response": []
        },
        {
          "name": "Show User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/users/{{userId}}",
            "description": "Necessite la permission user.read."
          },
          "response": []
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"bob\",\n  \"email\": \"bob@example.com\",\n  \"password\": \"motdepasse123\",\n  \"first_name\": \"Bob\",\n  \"last_name\": \"User\",\n  \"status\": \"active\",\n  \"role_codes\": [\"USER\"]\n}"
            },
            "url": "{{baseUrl}}/users",
            "description": "Necessite la permission user.create."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "    pm.collectionVariables.set('userId', String(json.data.id));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Bob Updated\",\n  \"last_name\": \"User Updated\",\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}",
            "description": "Necessite la permission user.update."
          },
          "response": []
        },
        {
          "name": "Sync User Roles",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role_codes\": [\"USER\"]\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/roles",
            "description": "Necessite la permission role.assign."
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/users/{{userId}}",
            "description": "Necessite la permission user.delete."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Roles",
      "item": [
        {
          "name": "List Roles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/roles",
            "description": "Necessite la permission role.read."
          },
          "response": []
        },
        {
          "name": "Show Role",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/roles/{{roleId}}",
            "description": "Necessite la permission role.read."
          },
          "response": []
        },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Manager\",\n  \"code\": \"MANAGER\",\n  \"description\": \"Role de demonstration\",\n  \"permission_codes\": [\"user.read\", \"role.read\"]\n}"
            },
            "url": "{{baseUrl}}/roles",
            "description": "Necessite la permission role.create."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "    pm.collectionVariables.set('roleId', String(json.data.id));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Manager Updated\",\n  \"description\": \"Role de demonstration modifie\"\n}"
            },
            "url": "{{baseUrl}}/roles/{{roleId}}",
            "description": "Necessite la permission role.update."
          },
          "response": []
        },
        {
          "name": "List Permissions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/permissions",
            "description": "Necessite la permission permission.read."
          },
          "response": []
        },
        {
          "name": "Sync Role Permissions",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permission_codes\": [\"user.read\", \"user.update\", \"role.read\"]\n}"
            },
            "url": "{{baseUrl}}/roles/{{roleId}}/permissions",
            "description": "Necessite la permission permission.assign."
          },
          "response": []
        },
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/roles/{{roleId}}",
            "description": "Necessite la permission role.delete. Les roles systeme ne peuvent pas etre supprimes."
          },
          "response": []
        }
      ]
    }
  ]
}